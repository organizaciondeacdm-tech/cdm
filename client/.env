# ═══════════════════════════════════════════════════════
# CONFIGURACIÓN DEFAULT - NO MODIFICAR
# ═══════════════════════════════════════════════════════
# La URL de API se detecta en RUNTIME en apiConfig.js
# No usar variables VITE_API_URL - se hardcodean en build
# ═══════════════════════════════════════════════════════

# Variables vacías = auto-detección en runtime
VITE_API_TIMEOUT=30000
VITE_DEBUG=false
VITE_ENABLE_LOGS=true
VITE_ENABLE_DEVTOOLS=false

