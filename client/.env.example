# ═══════════════════════════════════════════════════════
# CONFIGURACIÓN DEL CLIENTE REACT/VITE - PLANTILLA
# ═══════════════════════════════════════════════════════
# Este archivo es una referencia. Los archivos reales:
#   - .env.development: desarrollo local (http://localhost:5000)
#   - .env.production: producción (auto-detección)
#   - .env: caso general (auto-detección)
# ═══════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════
# API
# ═══════════════════════════════════════════════════════
# Vacío para auto-detección en producción
# En desarrollo: http://localhost:5000
VITE_API_URL=
VITE_API_TIMEOUT=30000

# ═══════════════════════════════════════════════════════
# DEBUG Y LOGGING
# ═══════════════════════════════════════════════════════
VITE_DEBUG=false
VITE_ENABLE_LOGS=false
VITE_ENABLE_DEVTOOLS=false

# ═══════════════════════════════════════════════════════
# CARACTERÍSTICAS OPCIONALES
# ═══════════════════════════════════════════════════════
# Agregar más variables según sea necesario
# VITE_ANALYTICS_ID=ua-xxxxxxx-x
# VITE_SENTRY_DSN=https://...
