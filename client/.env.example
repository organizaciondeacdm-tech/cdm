# ═══════════════════════════════════════════════════════
# CONFIGURACIÓN DEL CLIENTE REACT/VITE
# ═══════════════════════════════════════════════════════
# Este archivo es una plantilla. Usa:
#   - .env.development para desarrollo local
#   - .env.production para producción
#   - .env.vercel para Vercel
# ═══════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════
# API
# ═══════════════════════════════════════════════════════
# DEVELOPMENT: http://localhost:5000
# PRODUCTION: (vacío - detecta automáticamente)
# VERCEL: (vacío - usa window.location.origin)
VITE_API_URL=http://localhost:5000
VITE_API_TIMEOUT=30000

# ═══════════════════════════════════════════════════════
# DEBUG Y LOGGING
# ═══════════════════════════════════════════════════════
# DEVELOPMENT: true
# PRODUCTION: false
VITE_DEBUG=true
VITE_ENABLE_LOGS=true
VITE_ENABLE_DEVTOOLS=true

# ═══════════════════════════════════════════════════════
# CARACTERÍSTICAS OPCIONALES
# ═══════════════════════════════════════════════════════
# Agregar más variables según sea necesario
# VITE_ANALYTICS_ID=ua-xxxxxxx-x
# VITE_SENTRY_DSN=https://...
