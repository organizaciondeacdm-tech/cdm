{
  "name": "acdm-backend",
  "version": "1.0.0",
  "description": "Backend para Sistema ACDM - Gestión de Asistentes de Clase",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "dev:frontend": "vite",
    "build": "npm run build:frontend",
    "build:frontend": "vite build",
    "preview": "vite preview",
    "seed": "node src/config/seed.js",
    "seed:env": "node src/config/seedRuntimeEnv.js",
    "encrypt:uri": "node scripts/encrypt-uri.js",
    "sync:vercel": "vercel env pull .env.development.local",
    "sync:vercel:seed": "node scripts/seed-vercel-env.js",
    "backup": "node src/services/backupService.js",
    "test": "E2E_DISABLE_RATE_LIMIT=1 playwright test",
    "test:e2e:all": "E2E_DISABLE_RATE_LIMIT=1 playwright test",
    "test:e2e:existing": "E2E_SKIP_WEBSERVER=1 E2E_DISABLE_RATE_LIMIT=1 playwright test",
    "test:e2e:list": "playwright test --list",
    "test:ui": "E2E_DISABLE_RATE_LIMIT=1 playwright test --ui",
    "test:debug": "E2E_DISABLE_RATE_LIMIT=1 playwright test --debug",
    "test:report": "playwright show-report",
    "test:map": "node scripts/generate-test-coverage-structure.js",
    "test:map:strict": "node scripts/generate-test-coverage-structure.js --strict",
    "test:segments:gen": "npm run test:map && node scripts/generate-incremental-test-segments.js",
    "test:segments:list": "playwright test --list tests/e2e/segments",
    "test:segments:api:1": "playwright test tests/e2e/segments/api/segment-01.structural.spec.js",
    "test:e2e:incremental": "node scripts/run-e2e-incremental.js",
    "test:e2e:incremental:smoke": "node scripts/run-e2e-incremental.js --phase=smoke",
    "test:e2e:incremental:api": "node scripts/run-e2e-incremental.js --phase=core-api",
    "test:e2e:incremental:ui": "node scripts/run-e2e-incremental.js --phase=ui",
    "test:e2e:incremental:segments": "node scripts/run-e2e-incremental.js --phase=segments-api-structural"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.1.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie": "1.1.1",
    "cors": "^2.8.5",
    "destroy": "1.2.0",
    "dotenv": "^16.3.1",
    "etag": "1.8.1",
    "express": "4.22.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^6.10.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.0.0",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.18.0",
    "mongoose": "9.2.4",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.2",
    "nodemailer": "^8.0.1",
    "on-finished": "2.4.1",
    "pdfkit": "^0.17.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "serve-static": "2.2.1",
    "typeorm": "^0.3.27",
    "unpipe": "1.0.0",
    "utils-merge": "1.0.1",
    "vary": "1.1.2",
    "vite": "^5.0.0",
    "xss": "^1.0.14"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "nodemon": "^3.0.1",
    "terser": "^5.29.0"
  }
}