{
  "version": 2,
  "buildCommand": "npm install && npm run build:frontend",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "nodejs",
  "nodeVersion": "24.x",
  "env": {
    "NODE_ENV": "production",
    "VERCEL": "true"
  },
  "functions": {
    "api/index.js": {
      "runtime": "nodejs24.x",
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/dist/index.html"
    }
  ]
}
